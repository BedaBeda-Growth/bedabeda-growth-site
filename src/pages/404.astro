---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header';
import Footer from '@/components/Footer';
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist."
>
  <Header client:load />
  <main class="pt-24 pb-20 min-h-[60vh] flex items-center justify-center">
    <div class="container mx-auto px-6 text-center">
      <h1 class="text-6xl lg:text-8xl font-bold text-primary mb-4">404</h1>
      <h2 class="text-2xl lg:text-3xl font-bold text-foreground mb-4">Page Not Found</h2>
      <p class="text-gray-600 mb-8 max-w-md mx-auto">
        Sorry, the page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-flex items-center justify-center bg-primary hover:bg-primary/90 text-primary-foreground font-semibold px-8 py-4 rounded-lg transition-all"
      >
        Go Back Home
      </a>
    </div>
  </main>
  <Footer />
</BaseLayout>
